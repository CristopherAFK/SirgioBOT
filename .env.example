# Discord Bot Token
DISCORD_TOKEN=tu_token_de_discord_aqui
# O también puedes usar:
# TOKEN=tu_token_de_discord_aqui

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/sirgiobot
# O también puedes usar:
# MONGO_URI=mongodb://localhost:27017/sirgiobot

# Puerto para el servidor web (opcional, por defecto 5000)
PORT=5000
